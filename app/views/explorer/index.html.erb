<h1>📁 File Explorer</h1>
<turbo-frame id="image_modal"></turbo-frame>

<% if @current_path %>
  <h2>Path: <%= @current_path %></h2>

  <% parent = File.expand_path("..", @current_path) %>
  <% if @allowed_roots.any? { |root| parent.start_with?(root) } %>
    <%= link_to "⬅️ Back", explore_path(path: CGI.escape(parent)) %>
  <% end %>

  <h3>Folders</h3>
  <ul>
    <% @folders.each do |folder| %>
      <li>
        <%= link_to folder, explore_path(path: CGI.escape(File.join(@current_path, folder))) %>
      </li>
    <% end %>
  </ul>

  <h3>Images</h3>
  <div style="display: flex; flex-wrap: wrap;">
    <% @images.each do |image| %>
      <% full_path = File.join(@current_path, image) %>
      # <a href="#" data-action="click->image#open" data-image-url="<%= explorer_show_image_path(path: full_path) %>">
      #   <img src="<%= media_path(path: full_path) %>" style="width: 100px; height: 100px; object-fit: cover;" />
      # </a>
      <% full_path = File.join(@current_path, image) %>

      <%= button_to explorer_show_image_path(path: full_path),
                    method: :get,
                    form: { data: { turbo_frame: "image_modal" } },
                    class: "block",
                    style: "all: unset; cursor: pointer;" do %>

        <img src="<%= media_path(path: full_path) %>" style="width: 100px; height: 100px; object-fit: cover;" />
        <p><%= image %></p>
      <% end %>
    </div>
    <% end %>
  </div>

  <div style="margin-top: 30px;">
    <button onclick="alert('Run scan here')">📸 Scan</button>
    <button onclick="alert('Tag media')">🏷️ Tag</button>
  </div>

<% else %>
  <h2>Select a folder to explore:</h2>
  <ul>
    <% @roots.each do |path| %>
      <li><%= link_to File.basename(path), explore_path(path: CGI.escape(path)) %></li>
    <% end %>
  </ul>
<% end %>
